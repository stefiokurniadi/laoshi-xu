NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for bulk import scripts. Use service_role from
# Supabase Dashboard → Settings → API — NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=

# Superadmin panel (/admin): must match the auth user’s email. Also keep in sync with
# `get_leaderboard_snapshot` exclusion in supabase/schema.sql (superadmin@laoshixu.com).
# Create this user in Supabase Dashboard → Authentication (use a strong password; never commit it).
# SUPERADMIN_EMAIL=superadmin@laoshixu.com

# Default: npm run import-hsk / import-hsk30 → drkameleon/complete-hsk-vocabulary (JSON)
# https://github.com/drkameleon/complete-hsk-vocabulary
# HSK_COMPLETE_JSON_URL=   (optional: default complete.json raw on main)
# HSK_79_LEVEL=8           (new/newest-7 → this DB level)
# HSK_COMPLETE_REPLACE=1   (or HSK30_REPLACE=1) — wipe hsk_words before insert
#
# Alternatives:
# npm run import-hsk-ivankra — ivankra/hsk30 CSV (HSK30_CSV_URL, HSK30_REPLACE)
# npm run import-hsk-krmanik — krmanik TSVs (HSK_KRMANIK_BASE)

# scripts/translate-hsk-english.mjs — one provider: google | deepl | gemini | deepseek
# GOOGLE_TRANSLATE_API_KEY=
# DEEPL_AUTH_KEY=
# Laoshi Gemini Advise (logged-in study tips; server-only key). Tips auto-generate every 100 scored
# answers, capped at 5 per UTC day; SUPABASE_SERVICE_ROLE_KEY logs rows in gemini_usage.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# DEEPSEEK_API_KEY=
# DEEPSEEK_API_BASE=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# TRANSLATION_PROVIDER=gemini
# TRANSLATE_BATCH_SIZE=20
# TRANSLATE_MS_BETWEEN_BATCH=400
# TRANSLATE_DRY_RUN=1
# TRANSLATE_LIMIT=10
# TRANSLATE_FROM_ID=   (resume: min id to process)

# Google sign-in: enable the Google provider in Supabase Dashboard → Authentication → Providers,
# then add the redirect URL below to Google Cloud Console (OAuth client) authorized redirect URIs
# (Supabase shows the exact callback URL, e.g. https://<project>.supabase.co/auth/v1/callback).
# App callback route: `${NEXT_PUBLIC_SITE_URL}/auth/callback` (already used by signInWithGoogle).

# OAuth redirects, SEO (canonical, Open Graph, sitemap.xml, robots.txt).
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel Preview / staging (use the real preview URL or dev subdomain — must match where the app is served):
# NEXT_PUBLIC_SITE_URL=https://<your-project>.vercel.app
# Production (canonical host — use www; apex laoshixu.com redirects to www in next.config.ts):
# NEXT_PUBLIC_SITE_URL=https://www.laoshixu.com
#
# Dev/staging: use a separate Supabase project (or Supabase branching). Copy this file to .env.local
# with the *dev* NEXT_PUBLIC_SUPABASE_* and SUPABASE_SERVICE_ROLE_KEY — never use production keys on Preview.

# --- Anti-spam / anti-bot (recommended for production) ---
# Upstash Redis (free tier): rate limits on /api/word*, sign-in, sign-up, resend email.
# Create a database at https://upstash.com — paste REST URL + token here.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile (free): human check on email sign-in / sign-up when both are set.
# Dashboard: https://dash.cloudflare.com/ → Turnstile → create widget → site key + secret.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Secret gate `/tiniwinibiti` (PIN + signed-in). Toggle Google login uses `app_settings` via service role.
# TINIWINIBITI_PIN=4849**
# SUPABASE_SERVICE_ROLE_KEY must be set in the Next.js server env to save the Google on/off toggle.
